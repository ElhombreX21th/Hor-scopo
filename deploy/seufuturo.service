[Unit]
Description=SeuFuturo FastAPI service
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/seufuturo
Environment=HOST=0.0.0.0
Environment=PORT=8000
Environment=HOROSCOPO_DB_PATH=/opt/seufuturo/backend/horoscopo.db
Environment=APP_BASE_URL=https://seufuturo.blog.br
Environment=ALLOWED_ORIGINS=https://seufuturo.blog.br
Environment=ADMIN_TOKEN=CHANGEME
ExecStart=/usr/bin/env uvicorn backend.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
