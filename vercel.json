{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/docs",
      "dest": "api/index.py"
    },
    {
      "src": "/openapi.json",
      "dest": "api/index.py"
    },
    {
      "src": "/service-worker.js",
      "dest": "frontend/service-worker.js",
      "headers": {
        "Cache-Control": "public, max-age=0, must-revalidate"
      }
    },
    {
      "src": "/manifest.json",
      "dest": "frontend/manifest.json",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    },
    {
      "src": "/icons/(.*)",
      "dest": "frontend/icons/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/privacy",
      "dest": "frontend/privacy.html"
    },
    {
      "src": "/privacy.html",
      "dest": "frontend/privacy.html"
    },
    {
      "src": "/terms",
      "dest": "frontend/terms.html"
    },
    {
      "src": "/terms.html",
      "dest": "frontend/terms.html"
    },
    {
      "src": "/confirmacao-assinatura",
      "dest": "frontend/confirmacao-assinatura.html"
    },
    {
      "src": "/confirmacao-assinatura.html",
      "dest": "frontend/confirmacao-assinatura.html"
    },
    {
      "src": "/app-details",
      "dest": "frontend/app-details.html"
    },
    {
      "src": "/app-details.html",
      "dest": "frontend/app-details.html"
    },
    {
      "src": "/account-deletion",
      "dest": "frontend/account-deletion.html"
    },
    {
      "src": "/account-deletion.html",
      "dest": "frontend/account-deletion.html"
    },
    {
      "src": "/",
      "dest": "frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
