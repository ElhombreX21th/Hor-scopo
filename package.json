{
  "name": "seufuturo",
  "version": "1.0.0",
  "private": true,
  "description": "SeuFuturo PWA packaged with Capacitor for App Store and Google Play distribution.",
  "scripts": {
    "build:css": "tailwindcss -i ./frontend/styles/input.css -o ./frontend/styles/tailwind.css --minify",
    "build:store": "npm run build:css && node scripts/prepare-store-web.mjs && node scripts/cap-sync-store.mjs",
    "cap:sync": "cap sync",
    "cap:copy": "cap copy",
    "ios:add": "cap add ios",
    "ios:sync": "cap sync ios",
    "ios:open": "cap open ios",
    "android:add": "cap add android",
    "android:sync": "cap sync android",
    "android:open": "cap open android",
    "android:bundle": "cd android && gradlew bundleRelease",
    "android:bundle:win": "powershell -ExecutionPolicy Bypass -File scripts/build-android-bundle.ps1",
    "store:screenshots": "node scripts/generate-store-screenshots.mjs",
    "store:check": "node scripts/check-store-readiness.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3"
  }
}
