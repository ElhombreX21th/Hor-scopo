APP_NAME=SeuFuturo
APP_BASE_URL=https://seufuturo.blog.br
ALLOWED_ORIGINS=https://seufuturo.blog.br

# Backend storage
# Local/dev default uses SQLite. In Vercel production, set DATABASE_URL or POSTGRES_URL.
# Without a persistent Postgres URL, account and payment routes return 503 instead of losing users.
DATABASE_URL=
HOROSCOPO_DB_PATH=backend/horoscopo.db
HOROSCOPO_RUNTIME_DIR=backend

# Admin
ADMIN_TOKEN=troque_este_token_admin

# PayPal Checkout
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=

# Mercado Pago PIX
MP_ACCESS_TOKEN=
MP_WEBHOOK_URL=https://seufuturo.blog.br/api/mercadopago/webhook

# Optional external astrology provider
ASTRO_API_URL=
ASTRO_API_KEY=

# Optional observability/logging
LOG_LEVEL=INFO
