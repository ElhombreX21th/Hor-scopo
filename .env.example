APP_NAME=SeuFuturo
APP_BASE_URL=https://hypersecit.com.br
ALLOWED_ORIGINS=https://hypersecit.com.br

# Backend storage
# Local/dev default uses SQLite. In Vercel production, set DATABASE_URL or POSTGRES_URL.
# Without a persistent Postgres URL, account and payment routes return 503 instead of losing users.
DATABASE_URL=
HOROSCOPO_DB_PATH=backend/horoscopo.db
HOROSCOPO_RUNTIME_DIR=backend

# Admin
ADMIN_TOKEN=troque_este_token_admin

# Stripe Billing / Checkout
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_VIP=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal Checkout
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=

# Mercado Pago PIX
MP_ACCESS_TOKEN=
MP_WEBHOOK_URL=https://hypersecit.com.br/api/mercadopago/webhook

# Optional external astrology provider
ASTRO_API_URL=
ASTRO_API_KEY=

# Optional observability/logging
LOG_LEVEL=INFO
